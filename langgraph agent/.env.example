# AiDE API
AIDE_API_TOKEN="your_aide_api_token"
AIDE_BASE_URL="https://aide.transit-technologies.ai/api/v1/brownfield/"
AIDE_CONFIGURATION_PROFILE="Transit"
AIDE_MODEL="gpt-4o-mini"
AIDE_AUDIO_MODEL="gpt-realtime-mini"
AIDE_AUDIO_PATH="completions"  # default path for audio/text completions
AIDE_REALTIME_PATH="realtime"  # WebSocket path for realtime voice
AIDE_INPUT_AUDIO_FORMAT="pcm16"  # raw 16-bit PCM frames from mic
AIDE_OUTPUT_AUDIO_FORMAT="opus"  # model replies as Opus
AIDE_SERVER_VAD="false"  # set true to let server detect start/stop speech
AIDE_SSL_VERIFY="true"   # true|false or path to CA bundle for self-signed certs
AIDE_AUDIO_TRANSPORT="http"  # http (completions endpoint) or realtime (websocket)

# Power BI REST API (Service Principal)
POWERBI_TENANT_ID="your_azure_ad_tenant_id"
POWERBI_CLIENT_ID="your_service_principal_client_id"
POWERBI_CLIENT_SECRET="your_service_principal_client_secret"
POWERBI_DATASET_ID="your_powerbi_dataset_id"
POWERBI_WORKSPACE_ID="your_powerbi_workspace_id_optional"
POWERBI_IMPERSONATED_USER="your.powerbi.user@company.com"
POWERBI_SERVER_NAME_FILTER="demo-evolution.ecolane.com"
POWERBI_RLS_ENABLED="true"
POWERBI_RLS_USERNAME="demo-evolution.ecolane.com"
POWERBI_RLS_ROLES="Agency"

# Optional overrides
KPI_GLOSSARY_PATH="src/pbi_agent/kpi_glossary.json"
FILTER_GLOSSARY_PATH="src/pbi_agent/filter_glossary.json"
KPI_FILTER_MAP_PATH="src/pbi_agent/kpi_filter_map.json"
REPORT_DEFAULTS_PATH="src/pbi_agent/report_defaults.json"
REPORT_PAGE_DEFAULTS_PATH="src/pbi_agent/report_page_defaults.json"
VISUAL_MAP_PATH="src/pbi_agent/visual_map.json"
